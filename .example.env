# GoVocal API credentials
# Get these from Admin > Tools > Public API Access in your GoVocal platform
GOVOCAL_BASE_URL=https://participate.scforum.org
GOVOCAL_CLIENT_ID=your_client_id_here
GOVOCAL_CLIENT_SECRET=your_client_secret_here

# Typeform API credentials
# Get your personal access token from https://admin.typeform.com/account#/section/tokens
TYPEFORM_TOKEN=your_typeform_token_here
